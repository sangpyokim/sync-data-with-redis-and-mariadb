COMPOSE_PROJECT_NAME=sync-node-2
NODE_ID=sync-node-2
ADVERTISE_IP=<MAC_2_IP>

MARIADB_VERSION=11.4
MARIADB_BIND_IP=0.0.0.0
MARIADB_PORT=3306
MARIADB_DATABASE=sync_lab
MARIADB_USER=sync_app
MARIADB_PASSWORD=change-me-mariadb-app
MARIADB_ROOT_PASSWORD=change-me-mariadb-root

REDIS_VERSION=7.4-alpine
REDIS_ROLE=replica
REDIS_BIND_IP=0.0.0.0
REDIS_PORT=6379
REDIS_PRIMARY_NAME=sync-master
REDIS_PRIMARY_HOST=<MAC_1_IP>
REDIS_PRIMARY_PORT=6379
REDIS_PASSWORD=change-me-redis

SENTINEL_BIND_IP=0.0.0.0
SENTINEL_PORT=26379
SENTINEL_PASSWORD=change-me-sentinel
SENTINEL_QUORUM=2
SENTINEL_DOWN_AFTER_MS=5000
SENTINEL_FAILOVER_TIMEOUT_MS=15000
WITNESS_SENTINEL_PORT=26380

